# =============================================================================
# Restaurant SaaS — Environment Variables
# Copy this file to .env and fill in real values before running locally.
# NEVER commit .env to version control.
# On Railway/Render: add these in the Environment/Variables panel.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# Public base URL (no trailing slash) — REQUIRED for webhook registration
# Railway: https://yourapp.up.railway.app
# Render:  https://yourapp.onrender.com
# Custom:  https://app.yourrestaurant.com
BASE_URL=https://your-app.onrender.com

# CORS — ⚠️ في الإنتاج أضف دومين Netlify الحقيقي — لا تترك * أبداً
# مثال: ALLOWED_ORIGINS=https://yourapp.netlify.app,https://yourdomain.com
# محلياً فقط:
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Minimum 32 chars — change this before deploying!
JWT_SECRET=change_this_secret_in_production_minimum_32_chars

# Session duration in hours (default 24)
SESSION_HOURS=24

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default) — use /data/restaurant.db in Docker for persistent volume
DB_PATH=./restaurant.db

# PostgreSQL (optional, overrides SQLite when set)
# Railway plugin provides DATABASE_URL automatically
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Backup settings (for scripts/backup.sh)
# BACKUP_DIR=./backups
# KEEP_DAYS=7

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for AI bot (gpt-4o-mini) and voice transcription (Whisper-1)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Telegram ─────────────────────────────────────────────────────────────────
# Configure per restaurant in Dashboard → Channels → Telegram
# Get token from @BotFather on Telegram
# After saving, click "Register Webhook" in the dashboard to auto-register:
#   Webhook URL: {BASE_URL}/webhook/telegram/{restaurant_id}

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Configure per restaurant in Dashboard → Channels → WhatsApp
# Required fields: Access Token, Phone Number ID, Verify Token
# Meta Developer Console webhook settings:
#   Callback URL:  {BASE_URL}/webhook/whatsapp/{restaurant_id}
#   Verify Token:  (the verify_token you set in the channel)
#   Subscribe to:  messages

# ── Instagram Messaging ───────────────────────────────────────────────────────
# Configure per restaurant in Dashboard → Channels → Instagram
# Required fields: Page Access Token, Verify Token, App Secret
# Meta webhook settings:
#   Callback URL:  {BASE_URL}/webhook/instagram/{restaurant_id}
#   Verify Token:  (the verify_token you set in the channel)
#   Subscribe to:  messages, messaging_postbacks

# ── Facebook Messenger ────────────────────────────────────────────────────────
# Configure per restaurant in Dashboard → Channels → Facebook
# Required fields: Page Access Token, Verify Token, Page ID
# Meta webhook settings:
#   Callback URL:  {BASE_URL}/webhook/facebook/{restaurant_id}
#   Verify Token:  (the verify_token you set in the channel)
#   Subscribe to:  messages, messaging_postbacks

# ── Super Admin ───────────────────────────────────────────────────────────────
# Auto-seeded on first run:  superadmin@platform.com / super123
# Login at: {BASE_URL}/super/login
# Change password immediately after first login!

# ── Demo Restaurant (seed) ────────────────────────────────────────────────────
# Auto-seeded on first run:  admin@restaurant.com / admin123
# Login at: {BASE_URL}/
# Change credentials after first login via Dashboard → Settings

# ── Meta Platform (Facebook / Instagram / WhatsApp) ──────────────────────────
# Get from: developers.facebook.com → Your App → Settings → Basic
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# أنشئ قيمة عشوائية: python3 -c "import secrets; print(secrets.token_hex(32))"
# ثم انسخها هنا وفي Meta Developer Console → Webhooks → Verify Token
# نفس التوكن يشتغل لـ Facebook و Instagram و WhatsApp
META_VERIFY_TOKEN=your_custom_verify_token

# WhatsApp Embedded Signup ONLY — هذا ليس APP_ID
# احصل عليه من: Meta Business Manager → Apps → تطبيقك → Facebook Login for Business → Create Configuration → Configuration ID
# بدون هذا المتغير زر "ربط WhatsApp" لن يعمل
META_WA_CONFIG_ID=your_wa_configuration_id

# Meta Developer Console — الإعدادات المطلوبة:
#   Valid OAuth Redirect URI:  {BASE_URL}/oauth/meta/callback
#   Webhook Callback URL:      {BASE_URL}/webhooks/meta
#   Verify Token:              (نفس قيمة META_VERIFY_TOKEN أعلاه)

# ── Supabase Storage ─────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
#
# ┌─────────────────────────────────────────────────────────────────┐
# │  أين يذهب كل مفتاح؟                                            │
# │                                                                 │
# │  SUPABASE_URL          → Backend (Railway) + Netlify (frontend) │
# │  SUPABASE_ANON_KEY     → Backend (Railway) + Netlify (frontend) │
# │  SUPABASE_SERVICE_ROLE_KEY → Backend (Railway) فقط ⚠️          │
# │                        لا تضعه في Netlify أبداً                │
# └─────────────────────────────────────────────────────────────────┘
#
# سياسة Supabase Storage الموصى بها:
#   - Bucket "menus"    : public للقراءة، الكتابة عبر backend فقط
#   - Bucket "products" : public للقراءة، الكتابة عبر backend فقط
#   - لا تفتح INSERT من الـ anon role — الرفع كله يمر عبر /api/upload

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key_safe_for_frontend...
SUPABASE_SERVICE_ROLE_KEY=eyJ...BACKEND_ONLY_NEVER_EXPOSE...
SUPABASE_STORAGE_BUCKET_MENUS=menus
SUPABASE_STORAGE_BUCKET_PRODUCTS=products












